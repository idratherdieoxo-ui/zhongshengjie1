  "constraints": [
    {
      "id": "ANTI_001",
      "category": "视角反叛",
      "trigger_scene_types": ["战斗", "高潮", "打脸"],
      "constraint_text": "本场必须从败者/被动方的视角写，禁用主角内心视角。所有主角动作只能通过败者的感官呈现。",
      "intensity": "hard",
      "status": "active"
    },
    {
      "id": "ANTI_002",
      "category": "视角反叛",
      "trigger_scene_types": ["战斗", "打脸", "修炼突破"],
      "constraint_text": "用旁观者（路人、仆从、无关角色）的视角写，主角只是画面中的一个人。",
      "intensity": "hard",
      "status": "active"
    },
    {
